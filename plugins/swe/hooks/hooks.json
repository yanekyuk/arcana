{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/sensitive-file-blocker.sh",
            "description": "Blocks git add of sensitive files (.env, credentials, *.key, *.pem)"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/commit-msg-validator.sh",
            "description": "Validates conventional commit format on git commit -m"
          }
        ]
      },
      {
        "matcher": "Bash|EnterWorktree|ExitWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/worktree-boundary.sh",
            "description": "Prevents agent from navigating between worktrees"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/tdd-test-first.sh",
            "description": "Enforces test-first TDD — blocks implementation writes until test is run"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/tdd-test-tracker.sh",
            "description": "Tracks test execution to update TDD state machine"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "feat-orchestrator|fix-orchestrator|refactor-orchestrator|docs-orchestrator",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/orchestrator-completion-check.sh",
            "description": "Ensures orchestrators create a PR before finishing"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-feedback-extractor.sh",
            "description": "Extracts user corrections and learnings from session transcript"
          }
        ]
      }
    ]
  }
}
